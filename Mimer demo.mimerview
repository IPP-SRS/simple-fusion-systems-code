"screen\">\n\t\t.monaco-editor .codelens-decoration._ee1f61 { line-height: 13px; font-size: 10px; padding-right: 5px; font-feature-settings: var(--codelens-font-features_ee1f61) }\n\t\t.monaco-editor .codelens-decoration._ee1f61 span.codicon { line-height: 13px; font-size: 10px; }\n\t\t</style><script async=\"async\" type=\"text/javascript\" src=\"../monaco/min/vs/basic-languages/python/python.js\"></script></head>\n\n<body onbeforeunload=\"return OnBeforeReload()\" onresize=\"toggleZoomScreen()\" onload=\"toggleZoomScreen()\" style=\"background-color: white; overflow: hidden;\">\n    <div id=\"popup\" style=\"color: white; text-shadow: black -10px 0px 20px, black 0px 10px 20px, black 10px 0px 20px, black 0px -10px 20px; display: none; font-size: larger; z-index: 1002; position: fixed; height: 100%; width: 100%; padding: 70px 0px; background-color: rgba(0, 0, 0, 0.1); text-align: center; left: 0px; top: 0px;\"><h3>Wait for Python to load (may take a few moments)...</h3></div> \n    <script>\n        function OpenPopup(text) {\n            var popup=document.getElementById(\"popup\");\n            var popuptext = popup.getElementsByTagName('h3')[0]\n            popuptext.textContent = text;\n            popup.style.display = \"block\";\n        }\n        function ClosePopup() {\n            var popup=document.getElementById(\"popup\");\n            popup.style.display = \"none\";\n        }\n        function PopupIsOpen() {\n            var popup=document.getElementById(\"popup\");\n            return popup.style.display == \"block\";\n        }\n    </script>\n\n<div id=\"all\" ondrop=\"handleFileDrop(event);\" ondragover=\"handleDragOver(event);\" style=\"width: calc(100%); height: calc(100%); position: absolute; display: flex; flex-direction: column;\">\n    <div id=\"top\" style=\"height: calc(100% - 25px); float: left; overflow: hidden; display: flex;\">\n        <div id=\"menu\" class=\"interact-resize-r\" style=\"line-height: 11px; position: relative; width: 125px; min-width: 100px; height: 100%; border-right: 1px solid black; overflow: hidden; resize: horizontal; --mx: 98; --my: 105;\">\n            <button class=\"bottombutton\" style=\"height: 30px; width: 100%; margin-bottom: 10px; --mx: 80; --my: 20;\" onclick=\"document.getElementById('tutorial_link').click()\"><div class=\"nf nf-cod-book\"></div> Tutorials</button>\n            \n            <button style=\"display: block; width: 100%; height: 30px; --mx: 80; --my: 28;\" onclick=\"document.getElementById('inputfile').click()\"><div class=\"nf nf-oct-upload\" style=\"--mx: -0.9895834922790527; --my: 0.7777748107910156;\"></div>Load Dataset</button>\n            <input type=\"file\" name=\"inputfile\" id=\"inputfile\" style=\"display:none\">\n\n            <button style=\"display: block; width: 100%; height: 30px; --mx: 67; --my: 28;\" onclick=\"StorageButtonClick()\"><div class=\"nf nf-fa-upload\"></div>Load Storage</button>\n            <!-- <br> -->\n            <button class=\"bottombutton\" style=\"display: block; width: 100%; height: 30px; --mx: 71; --my: 3.9999923706054688;\" onclick=\"save_options.Open(); AddCloseButton();\"><div class=\"nf nf-oct-download\"></div>Save dataset</button>\n\n            <br>\n            <h1 style=\"--mx: 61; --my: 5.2985992431640625;\">Process data</h1>\n            <button style=\"display: block; width: 100%; height: 25px; --mx: 54; --my: 2.5972137451171875;\" onclick=\"fpm_options.Open();\">\n                <div class=\"nf nf-fa-share_alt\"></div>\n                FPM\n                <pre class=\"tooltiptext\" style=\"top: 150.625px; left: 130px;\">Run <span style=\"color: var(--button-color-full)\">Flexible Pattern Mining</span>\nfor knowledge discovery</pre>\n            </button>\n            <button style=\"display: block; width: 100%; height: 25px; --mx: 44; --my: -0.4027862548828125;\" onclick=\"nds_options.Open();\">\n                <div class=\"nf nf-md-sort_reverse_variant\" style=\"--mx: 8.010416507720947; --my: 3.8749847412109375;\"></div>\n                NDS\n                <pre class=\"tooltiptext\" style=\"top: 175.625px; left: 130px;\">Run <span style=\"color: var(--button-color-full)\">Non-Dominated Sorting</span>\nand divide solutions into ranks</pre>\n            </button>\n            <div style=\"display: flex; width:100%\">        \n            <button style=\"float: left; display: block; height: 25px; flex-grow: 1; --mx: 41; --my: 4.5972137451171875;\" onclick=\"infsp_options.Open();\">\n                <div class=\"nf nf-md-chart_bar\"></div>\n                InfS-P\n                <pre class=\"tooltiptext\" style=\"top: 200.625px; left: 130px;\">Run <span style=\"color: var(--button-color-full)\">InfS-P</span> and find important variables\nfor <span style=\"color: var(--button-color-full)\">diversity</span> on the Pareto-front</pre>\n            </button>\n            <button class=\"rightbutton\" style=\"display: block; height: 25px; flex-grow: 1; --mx: 24.00347137451172; --my: 21.597213745117188;\" onclick=\"infsr_options.Open();\">\n                InfS-R\n                <pre class=\"tooltiptext\" style=\"top: 200.625px; left: 130px;\">Run <span style=\"color: var(--button-color-full)\">InfS-R</span> and find important variables\nfor <span style=\"color: var(--button-color-full)\">convergence</span> towards the Pareto-front</pre>\n            </button>\n            \n            </div>\n            <button style=\"display: block; width: 100%; height: 37px; --mx: 42; --my: 4.5972137451171875;\" onclick=\"filter_options.Open();\">\n                        <div class=\"nf nf-md-filter_cog\" style=\"height: 100%; text-align: center; display: flex; justify-content: center; align-items: center; --mx: 7.010416507720947; --my: 7.49652099609375;\"></div>\n                        Filter &amp;<br> Highlight\n                    </button>\n            <button style=\"display: block; width: 100%; height: 25px; --mx: 85; --my: 22.600677490234375;\" onclick=\"color_options.Open();\"><div class=\"nf nf-fae-palette_color\"></div>Color lab</button>\n            <button style=\"display: block; width: 100%; height: 25px; --mx: 45; --my: 21.600677490234375;\" onclick=\"cluster_options.Open();\"><div class=\"nf nf-md-scatter_plot\" style=\"--mx: 7.010416507720947; --my: 4.878448486328125;\"></div>Cluster</button>\n            <button class=\"bottombutton\" style=\"display: block; width: 100%; height: 25px; --mx: 0; --my: -1.399322509765625;\" onclick=\"indicator_options.Open();\"><div class=\"nf nf-fae-triangle_ruler\"></div>Indicators</button>\n           \n            <div style=\"overflow: auto; position: relative; height: calc(100% - 435px); --mx: 72; --my: 10.600677490234375;\">\n            <br>\n                <h1 style=\"--mx: 114; --my: 8.8992919921875;\">Datasets</h1>\n                <div id=\"datasets\" style=\"position: relative; max-height: 50%; overflow-x: hidden; overflow-y: auto; font-size: 0; line-height: 0;\"><div style=\"display: flex; margin: 0px; padding: 0px;\"><button class=\"bottombutton\" style=\"width: 10px; padding-left: 3px;\">⋮</button><button class=\"bottombutton lastdataset\" style=\"color: black; padding: 2px; margin: 0px; flex-grow: 1; text-align: left; --mx: 54; --my: 8.197906494140625;\">0: testfile.txt</button></div><br></div>\n\n            <br>\n                <h1 style=\"--mx: 90; --my: 1.510406494140625;\">Rulesets</h1>\n                <div id=\"FPMdatasets\" style=\"position: relative; max-height: 50%; overflow-x: hidden; overflow-y: auto; font-size: 0; line-height: 0;\"></div>\n            </div>\n\n            <div style=\"position: absolute; bottom: 0px; height: auto; width: 100%; --mx: 91; --my: 62.579833984375;\">\n                <h1>View</h1>\n                <button class=\"bottombutton\" style=\"float: left; display: block; width: 49%; height: 30px; --mx: 33; --my: 12.1666259765625;\" onclick=\"Click_Save()\"><div class=\"nf nf-oct-download\"></div>Save</button>\n                <script type=\"text/javascript\">\n                    function Click_Save() {\n                        var content = Save();\n                        var filename = \"view.mimerview\";\n                        var contentType = 'application/octet-stream';\n                        var a = document.createElement('a');\n                        var blob = new Blob([content], {'type':contentType});\n                        a.href = window.URL.createObjectURL(blob);\n                        a.download = filename;\n                        a.click();\n                    }\n                </script>\n                <button class=\"bottomrightbutton\" style=\"display: block; width: 51%; height: 30px; --mx: 4.305553436279297; --my: 15.1666259765625;\" onclick=\"document.getElementById('viewinputfile').click()\"><div class=\"nf nf-oct-upload\" style=\"--mx: 4.204856872558594; --my: 10.49993896484375;\"></div>Load</button>\n                <input type=\"file\" name=\"viewinputfile\" id=\"viewinputfile\" style=\"display:none\">\n                <script type=\"text/javascript\">\n                    document.getElementById('viewinputfile')\n                        .addEventListener('change', function() {\n                            Click_Load(this.files[0]);\n                            this.value = null;\n                        });\n                    function Click_Load(filename) {\n                        var fr=new FileReader();\n                        fr.onload=function(){\n                            var text = fr.result;\n                            Load_view(text);\n                        }\n                        \n                        fr.readAsText(filename);\n                    }\n                </script>\n\n                <hr>\n\n                <button style=\"display: block; width: 100%; height: 30px; --mx: 105; --my: -0.916748046875;\" onclick=\"ToggleConsole()\"><div class=\"nf nf-md-cog\"></div>Editor</button>\n                <script>\n                    var lastToggleHeight = 0;\n                    function ToggleConsole() {\n                        var cons = document.getElementById('console'); \n                        var main_c = document.getElementById('main_content');\n                        if ( cons.style.display == 'flex'){\n                            lastToggleHeight = main_c.style.height;\n\n                            cons.style.display = 'none';\n                            main_c.style.height = \"100%\";\n                            main_c.style.resize = \"none\";\n                        } else {\n                            cons.style.display = 'flex';\n                            main_c.style.resize = \"vertical\";\n\n                            main_c.style.height = lastToggleHeight;\n                        }\n                    }\n                </script>\n                <button style=\"display:block;width:100%; height:30px;\" onclick=\"recorder_options.Open();\"><div class=\"nf nf-md-movie_play\"></div>Recorder</button>\n            </div>\n        </div>\n        <script>\n            function UpdateMenuTooltips(){\n                let tooltips = document.getElementsByClassName('tooltiptext');\n                let menuRight = document.getElementById('menu').getBoundingClientRect().right;\n                for (let i = 0; i < tooltips.length; i++) {\n                    const prect = tooltips[i].parentElement.getBoundingClientRect();\n                    const trect = tooltips[i].getBoundingClientRect();\n\n                    const top = prect.top - (trect.height / 2);\n                    const left = menuRight + 5;\n                    tooltips[i].style.top = `${top}px`;\n                    tooltips[i].style.left = `${left}px`;\n                }\n            }\n            UpdateMenuTooltips();\n            let observer = new ResizeObserver(UpdateMenuTooltips);\n            observer.observe(document.getElementById('menu'));\n        </script>\n\n        \n        <div id=\"options\" style=\"position: relative; width: 235px; min-width: 235px; height: 100%; border-right: 1px solid black; overflow-y: auto; display: none; --mx: 141.99999237060547; --my: 37;\" onload=\"consol.log('loading')\"><div style=\"text-align: center; font-size: larger; --mx: 210.99999237060547; --my: 1;\"><span style=\"font-weight: bold;\">Save dataset</span></div><hr style=\"\"><div style=\"display: flex;\"><label style=\"float: left; width: 80px;\">Dataset:</label><select id=\"save_dataset\" class=\"save_dataset\" style=\"float: left; flex-grow: 1; --mx: 57.99998474121094; --my: 17.694442749023438;\" onchange=\"save_options.LoadStuff()\"><option>0: testfile.txt</option></select></div><h1 style=\"--mx: 13.999992370605469; --my: 15.982635498046875;\">Variables</h1><div id=\"columns\" style=\"width: 100%; height: 250px; overflow-y: scroll; float: left; background-color: lightgray; position: relative; --mx: 73.99999237060547; --my: -1.5069503784179688;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\"GrossElecPower\" id=\"cb_0\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_0\">GrossElecPower</label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap; --mx: 2.9999923706054688; --my: 16.534713745117188;\"><input type=\"checkbox\" value=\" WallLoad\" id=\"cb_1\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_1\"> WallLoad</label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\" BMax\" id=\"cb_2\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_2\"> BMax</label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\" SigmaMax\" id=\"cb_3\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_3\"> SigmaMax</label></div><br style=\"clear: both;\"><div style=\"width