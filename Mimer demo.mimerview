x; width: 0px; height: 146px;\"><div class=\"minimap-shadow-hidden\" style=\"height: 146px;\"></div><canvas width=\"0\" height=\"131\" style=\"position: absolute; left: 0px; width: 0px; height: 146px;\"></canvas><canvas class=\"minimap-decorations-layer\" width=\"0\" height=\"131\" style=\"position: absolute; left: 0px; width: 0px; height: 146px;\"></canvas><div class=\"minimap-slider\" style=\"position: absolute; transform: translate3d(0px, 0px, 0px); contain: strict; width: 0px;\"><div class=\"minimap-slider-horizontal\" style=\"position: absolute; width: 0px; height: 0px;\"></div></div></div></div><div data-mprt=\"2\" class=\"overflowingContentWidgets\"><div class=\"monaco-editor rename-box\" widgetid=\"__renameInputWidget\" style=\"background-color: rgb(243, 243, 243); box-shadow: rgba(0, 0, 0, 0.16) 0px 0px 8px 2px; color: rgb(97, 97, 97); position: fixed; display: none; visibility: hidden; max-width: 1653px;\"><input class=\"rename-input\" type=\"text\" aria-label=\"Rename input. Type new name and press Enter to commit.\" style=\"font-family: Consolas, &quot;Courier New&quot;, monospace; font-weight: normal; font-size: 12px; background-color: rgb(255, 255, 255); border-width: 0px; border-style: none;\"><div class=\"rename-label\" style=\"font-size: 9.6px;\">Enter to Rename, Shift+Enter to Preview</div></div><div class=\"monaco-hover hidden\" tabindex=\"0\" role=\"tooltip\" widgetid=\"editor.contrib.contentHoverWidget\" style=\"position: fixed; display: none; visibility: hidden; max-width: 2080px;\"><div class=\"monaco-scrollable-element \" role=\"presentation\" style=\"position: relative; overflow: hidden;\"><div class=\"monaco-hover-content\" style=\"overflow: hidden; font-size: 12px; line-height: 1.25; max-height: 250px; max-width: 772.86px;\"></div><div role=\"presentation\" aria-hidden=\"true\" class=\"invisible scrollbar horizontal\" style=\"position: absolute;\"><div class=\"slider\" style=\"position: absolute; top: 0px; left: 0px; height: 10px; transform: translate3d(0px, 0px, 0px); contain: strict;\"></div></div><div role=\"presentation\" aria-hidden=\"true\" class=\"invisible scrollbar vertical\" style=\"position: absolute;\"><div class=\"slider\" style=\"position: absolute; top: 0px; left: 0px; width: 10px; transform: translate3d(0px, 0px, 0px); contain: strict;\"></div></div><div class=\"shadow\"></div><div class=\"shadow\"></div><div class=\"shadow\"></div></div></div></div></div></div>\n                    <!-- <script>\n                        var require = { paths: { vs: '../monaco/min/vs' } };\n                    </script>  -->\n                    <!-- <script src=\"../monaco/min/vs/loader.js\"></script> -->\n                    <!-- <script src=\"../monaco/min/vs/editor/editor.main.nls.js\"></script>\n                    <script src=\"../monaco/min/vs/editor/editor.main.js\"></script> -->\n                    <script src=\"../js/pythonprovider.js\"></script>\n                    <script src=\"../js/pythoneditor.js\"></script>\n\n                    <script>\n                        if (typeof editor === 'undefined') {\n                            require = { paths: { vs: '../monaco/min/vs' } };\n\n                            var s1 = document.createElement('script');\n                            s1.type = \"text/javascript\";\n                            s1.src = '../monaco/min/vs/loader.js';\n\n                            s1.onload = function () {\n                                var s2 = document.createElement('script');\n                                s2.type = \"text/javascript\";\n                                s2.src = '../monaco/min/vs/editor/editor.main.nls.js';\n\n                                s2.onload = function () {\n                                    var s3 = document.createElement('script');\n                                    s3.type = \"text/javascript\";\n                                    s3.src = '../monaco/min/vs/editor/editor.main.js';\n\n                                    s3.onload = function() {\n                                        start_editor();\n\n                                        s1.remove();\n                                        s2.remove()\n                                        s3.remove();\n                                    }\n                                    document.body.appendChild(s3);\n                                }\n                                document.body.appendChild(s2);\n                            }   \n                            document.body.appendChild(s1);\n                        }\n\n                    </script>\n                    <div id=\"console_pages\" style=\"position: absolute; bottom: 0px; height: 25px; width: auto; overflow: auto;\">\n                        <button title=\"Start page\" class=\"editorpagebutton\" style=\"height: 100%; width: 100px; text-align: left; --mx: 10.999992370605469; --my: 9.083251953125;\"><span style=\"height: 10%; padding: 0px; position: absolute; left: 15px; top: 3px; pointer-events: none;\">Start page</span><button class=\"pythoninnerbutton\" style=\"height: 100%; width: 10px; padding: 0px; position: absolute; left: 0px; top: 0px;\">⋮</button><button class=\"pythoninnerbutton\" style=\"height: 100%; width: 10px; padding: 0px; position: absolute; right: 0px; top: 0px;\">x</button></button><button id=\"add_page_button\" style=\"border-style: solid solid none solid; height: 100%; width: height;\" onclick=\"python_editor.AddPage()\">+</button>\n                    </div>\n                </div>\n                <script type=\"text/javascript\" src=\"../js/consolescript.js\"></script>\n        \n                <div id=\"python_div\" style=\"flex: 1; width: 0px; background-color: #f6f6f6;\">\n                    <div id=\"console_scoll\" style=\"height: calc(100% - 30px); overflow: hidden auto; white-space: pre-wrap; overflow-wrap: break-word; --mx: 60.8089599609375; --my: 11.28118896484375;\">\n                        <pre style=\"float: left; width: 100%;\"><code class=\"language-python hljs\" id=\"console_output\" style=\"width: calc(100% - 20px); white-space: pre-wrap; overflow-wrap: break-word; --mx: 22.8089599609375; --my: 22.73956298828125;\"></code></pre>\n                    </div>\n                    <form action=\"\" onsubmit=\"Fclick(document.getElementById('console_input').value, true); return false;\" style=\"float: left; width: 100%;\">\n                        <input placeholder=\"Python command (enter to submit)\" spellcheck=\"false\" autocomplete=\"off\" type=\"text\" id=\"console_input\" style=\"width: 100%; height: 30px; --mx: 518.8089599609375; --my: 12.083251953125;\" onkeydown=\"ManageHistory(event)\" onkeyup=\"HandelIntellisenseInputConsole(event)\">\n                        <button type=\"submit\" ,=\"\" style=\"display: none;\"></button>\n                    </form>\n                </div>\n                <script type=\"text/javascript\">\n                    var historyList=[];\n                    var historyIndex = -1;\n                    function AddHistory(text) {\n                        historyList.push(text);\n                        historyIndex = historyList.length-1;\n                    }\n        \n                    function ManageHistory(event) {\n                        var cin = document.getElementById('console_input');\n                        if (event.keyCode == 38) {\n                            if (historyIndex>0) {\n                                cin.value = historyList[historyIndex--];\n                            } \n                            else if (historyIndex==0){\n                                cin.value = historyList[historyIndex];\n                            }\n                        }\n                        if (event.keyCode == 40) {\n                            if (historyIndex<historyList.length-1) {\n                                cin.value = historyList[historyIndex++];\n                            } \n                            else if (historyIndex==historyList.length-1){\n                                cin.value = historyList[historyIndex];\n                            }\n                        }\n        \n                        if (event.keyCode == 13) {\n                            AddHistory(document.getElementById('console_input').value);\n                        }\n\n                        if(event.code == \"Escape\") {\n                            CloseIntelliSense();\n                        }\n                    }\n\n                    function HandelIntellisenseInputConsole(event){\n                        var cin = document.getElementById('console_input');\n                        if (event.key == ' ' && event.ctrlKey) {\n                            //has_intelli = true;\n                        }\n                        if(has_intelli) {\n                            ShowIntellisense(cin, [cin.value.length,0], {top:cin.getBoundingClientRect().y, left:cin.offsetLeft+20});\n                        }\n                    }\n\n                    async function pyPrint(text) {\n                        console.log(text);\n\n                        var output = document.getElementById('console_output');\n                        output.textContent+=text.trim() + '\\n';\n\n                        for (var a=[],i=output.textContent.length; i--;) \n                            if (output.textContent[i]==\"\\n\") \n                                a.push(i);\n                        yyy = a;\n                        \n                        if (a.length > 1001) {\n                            output.textContent = output.textContent.slice(a[1001]);\n                        }\n\n                        // lines = output.textContent.split('\\n');\n                        // if (lines.length > 11) {\n                        //     // output.textContent = \"\";\n                        //     ttt = \"\";\n                        //     for (var i = lines.length-11; i < lines.length; i++) {\n                        //         // output.textContent += lines[i] + '\\n';\n                        //         ttt += lines[i].trim() + '\\n';\n                        //     }\n                        //     console.log('ttt', ttt);\n                        //     output.textContent = ttt;\n                        // }\n                        \n                        document.getElementById('console_input').value=\"\";\n                        hljs.highlightAll();\n                        var di = document.getElementById(\"console_scoll\")\n                        di.scrollTop = di.scrollHeight;\n\n                        await new Promise(resolve => setTimeout(resolve, 10));\n                    }\n        \n                    async function Fclick(text, print=false) {\n                        if (print) {\n                            pyPrint(text)\n                            document.getElementById('console_input').value=\"\";\n                        }\n\n                        await pyodide.runPythonAsync(text).then(ret=>{\n                            var output = '->\\t';\n                            if (ret != undefined) {\n                                output += ret + '\\n';\n                            }\n                            pyPrint(output);\n                        }).catch(err => {\n                            var output = \"\";\n                            output += err + '\\n';\n                            pyPrint(output);\n                        });\n                        \n                        var di = document.getElementById(\"console_scoll\")\n                        di.scrollTop = di.scrollHeight;\n                    }\n                    \n                    document.getElementById('console_input').value=\"\";\n                    hljs.highlightAll();\n                    var di = document.getElementById(\"console_scoll\")\n                    di.scrollTop = di.scrollHeight;\n                </script>\n            </div>\n        </div>\n    </div>\n    <div style=\"height: auto; line-height: 20px; border-top: 1px solid black; padding: 3px; --mx: 143; --my: 0.083251953125;\">\n                <a href=\"https://assar.his.se/mimer/html/\">Mimer</a>: A Web-Based Tool for Knowledge Discovery in Multi-Criteria Decision Support <br>Copyright (C) Henrik Smedberg 2023 (<a href=\"mailto:henrik.smedberg@his.se\">henrik.smedberg@his.se</a>) | <a target=\"_blank\" href=\"terms.html\">Terms of use</a> | <a id=\"tutorial_link\" target=\"_blank\" href=\"tutorials.html\">Tutorials</a> | <a target=\"_blank\" href=\"references.html\">References</a></div>\n\n</div>\n<script>\n    function handleFileDrop(ev) {\n        ev.preventDefault();\n\n        var files=[];\n\n        if (ev.dataTransfer.items) {\n            // Use DataTransferItemList interface to access the file(s)\n            for (var i = 0; i < ev.dataTransfer.items.length; i++) {\n            // If dropped items aren't files, reject them\n            if (ev.dataTransfer.items[i].kind === 'file') {\n                var file = ev.dataTransfer.items[i].getAsFile();\n                files.push(file);\n            }\n            }\n        } else {\n            // Use DataTransfer interface to access the file(s)\n            for (var i = 0; i < ev.dataTransfer.files.length; i++) {\n                files.push(ev.dataTransfer.files[i])\n            }\n        }\n\n        var done = false;\n        files.forEach(f => {\n            var ext = f.name.split('.').pop();\n            if (!done && ext == 'mimerview') {\n                Click_Load(f);\n                done = true;\n            }\n        })\n\n        if (!done) {\n            //files = files.sort((a,b)=>{return a.name.localeCompare(b.name, undefined, { numeric: true, sensitivity: 'base' });});\n\n            let utf8Encode = new TextEncoder();\n            var compFunc = (a, b) => {\n                var aListRaw = a.match(/\\d+|./g);\n                var aList = [];\n                var biggestNumber = 0;\n                for (let v of aListRaw) {\n                    let vv = parseInt(v);\n                    if (isNaN(vv))\n                        aList.push(v);\n                    else\n                        aList.push(vv);\n\n                    if (vv > biggestNumber) {\n                        biggestNumber = vv;\n                    }\n                }\n                var bListRaw = b.match(/\\d+|./g);\n                var bList = [];\n                for (let v of bListRaw) {\n                    let vv = parseInt(v);\n                    if (isNaN(vv))\n                        bList.push(v);\n                    else\n                        bList.push(vv);\n                        \n                    if (vv > biggestNumber) {\n                        biggestNumber = vv;\n                    }\n                }\n\n                for (let i = 0; i < aList.length; i++) {\n                    if (typeof aList[i] == \"string\") {\n                        aList[i] = utf8Encode.encode(aList[i])[0] + biggestNumber;\n                    }\n                }\n                for (let i = 0; i < bList.length; i++) {\n                    if (typeof bList[i] == \"string\") {\n                        bList[i] = utf8Encode.encode(bList[i])[0] + biggestNumber;\n                    }\n                }\n\n                let l = Math.max(aList.length, bList.length);\n                for (let i = 0; i < l; i++) {\n                    if (aList.length == i) \n                        return 1;\n                    if (bList.length == i)\n                        return -1;\n                    if (aList[i] - bList[i] != 0) {\n                        return aList[i] - bList[i];\n                    }\n                }\n\n                return 0;\n            }\n\n            // files = files.sort((a,b)=>{return a.lastModified - b.lastModified;});\n            files = files.sort((a,b)=>{return compFunc(a.name, b.name);});\n            (async () => {\n                for (let f of files) {\n                    await AddDataset(f);\n                }\n            })();\n        }\n    }\n\n    function handleDragOver(e){\n        e.preventDefault();\n    }\n</script>\n\n\n\n\n<script>\n    if (typeof Module === 'undefined') {\n        var Module = {};\n\n        (async () => {\n            fetch('../wasm/FPM.wasm')\n            .then(response =>\n                response.arrayBuffer()\n            ).then(buffer => {\n                Module.wasmBinary = buffer;\n                var script = document.createElement('script');\n                script.src = \"../wasm/FPM.js\";\n                script.onload = function() {\n                    console.log(\"Emscripten boilerplate loaded.\")\n                    script.remove();\n                }\n                document.body.appendChild(script);\n            });\n        })();\n    }\n</script>\n<script src=\"../js/remotecontrol.js\"></script>\n<script src=\"../js/storageadapter.js\"></script>\n<script src=\"../js/pythonscripts.js\"></script>\n<script src=\"../js/saver.js\"></script>\n<script src=\"../js/options.js\"></script>\n<script type=\"text/javascript\">\nfunction CreateCover() {\n    var cover = document.getElementById('cover');\n    if (!cover) {\n        cover = document.createElement('div');\n        cover.setAttribute('id', 'cover');\n        cover.style.height = '100%';\n        cover.style.width = '100%';\n        cover.style.position = 'absolute';\n        cover.style.zIndex = 100000;\n        document.getElementById('all').append(cover);\n    }\n}\nfunction RemoveCover() {\n    var cover = document.getElementById('cover');\n    cover.remove();\n}\n\ninteract('.resize-console')\n  .resizable({\n    edges: { left: false, right: true, bottom: false, top: false },\n\n    listeners: {\n      move (event) {\n        CreateCover();\n\n        var target = event.target;\n        var y = (parseFloat(target.getAttribute('data-y')) || 0)\n\n        // update the element's style\n        target.style.width = event.rect.width + 'px'\n      }\n    },\n\n    modifiers: [\n      // keep the edges inside the parent\n      interact.modifiers.restrictEdges({\n        outer: 'parent'\n      }),\n\n      // minimum size\n      interact.modifiers.restrictSize({\n        min: { width: 50, height: 50 }\n      })\n    ],\n\n    inertia: false\n  })\n  .on(['resizeend'], (event) => {RemoveCover(); event.target})\n\ninteract('.interact-resize-b')\n  .resizable({\n    // resize from all edges and corners\n    edges: { left: false, right: false, bottom: true, top: false },\n\n    listeners: {\n      move (event) {\n        CreateCover();\n\n        var target = event.target\n        var x = (parseFloat(target.getAttribute('data-x')) || 0)\n        var y = (parseFloat(target.getAttribute('data-y')) || 0)\n\n        // update the element's style\n        // target.style.width = event.rect.width + 'px'\n        target.style.height = event.rect.height/target.parentElement.parentElement.clientHeight*100 + '%'\n      }\n    },\n\n    modifiers: [\n      interact.modifiers.restrictEdges({\n        outer: 'parent'\n      }),\n\n      // minimum size\n      interact.modifiers.restrictSize({\n        min: { width: 50, height: 50 }\n      })\n    ],\n\n    inertia: false\n  })\n  .on(['resizeend'], (event) => {RemoveCover();})\n\ninteract('.interact-resize-r')\n  .resizable({\n    // resize from all edges and corners\n    edges: { left: false, right: true, bottom: false, top: false },\n\n    listeners: {\n      move (event) {\n        CreateCover();\n\n        var target = event.target\n        var x = (parseFloat(target.getAttribute('data-x')) || 0)\n        var y = (parseFloat(target.getAttribute('data-y')) || 0)\n\n        // update the element's style\n        target.style.width = event.rect.width + 'px'\n        if (target.style.width < target.style['min-width'])\n            target.style.width = target.style['min-width'];\n\n        // target.style.width = event.rect.width/target.parentElement.parentElement.width*100 + '%'\n      }\n    },\n\n    modifiers: [\n      interact.modifiers.restrictEdges({\n        outer: 'parent'\n      }),\n\n      // minimum size\n      interact.modifiers.restrictSize({\n        min: { width: 50, height: 50 }\n      })\n    ],\n\n    inertia: false\n  })\n  .on(['resizeend'], (event) => {RemoveCover();})\n\ninteract('.interact-resize-b-r')\n  .resizable({\n    // resize from all edges and corners\n    edges: { left: false, right: true, bottom: true, top: false },\n\n    listeners: {\n      move (event) {\n        CreateCover();\n\n        var target = event.target\n        var x = (parseFloat(target.getAttribute('data-x')) || 0)\n        var y = (parseFloat(target.getAttribute('data-y')) || 0)\n\n        // update the element's style\n        target.style.width = event.rect.width + 'px'\n        target.style.height = event.rect.height + 'px'\n      }\n    },\n    modifiers: [\n      interact.modifiers.restrictEdges({\n        outer: 'parent'\n      }),\n\n      // minimum size\n      interact.modifiers.restrictSize({\n        min: { width: 50, height: 50 }\n      })\n    ],\n\n    inertia: false\n  })\n  .on(['resizeend'], (event) => {\n      RemoveCover();\n    })\n</script>\n\n\n<div class=\"monaco-aria-container\"><div class=\"monaco-alert\" role=\"alert\" aria-atomic=\"true\"></div><div class=\"monaco-alert\" role=\"alert\" aria-atomic=\"true\"></div><div class=\"monaco-status\" role=\"complementary\" aria-live=\"polite\" aria-atomic=\"true\"></div><div class=\"monaco-status\" role=\"complementary\" aria-live=\"polite\" aria-atomic=\"true\"></div></div><div id=\"filter_option_saver\" style=\"display: none;\">\n                <p class=\"filter_option_save_rule\"></p>\n                <p class=\"filter_option_save_color\">#47ff7e</p>\n            </div></body></html>","gds":"[\"testfile.txt\"]","gfpmds":"[]","dfs":["GrossElecPower; WallLoad; BMax; SigmaMax; Li6; Neu