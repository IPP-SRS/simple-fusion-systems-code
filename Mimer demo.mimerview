\" class=\"checkbox\" style=\"float: left; --mx: 8.006942749023438; --my: 0.1874847412109375;\"><label for=\"cb_35\" style=\"--mx: 1.0347137451171875; --my: 7.1735992431640625;\"> MagThk</label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\" BlnkThk\" id=\"cb_36\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_36\"> BlnkThk</label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\" Bore\" id=\"cb_37\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_37\"> Bore</label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\" WallLoadCalc\" id=\"cb_38\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_38\"> WallLoadCalc</label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\" ExitCode\" id=\"cb_39\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_39\"> ExitCode</label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\" \" id=\"cb_40\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_40\"> </label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\"__highlight_color\" id=\"cb_41\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_41\">__highlight_color</label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\"__filter\" id=\"cb_42\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_42\">__filter</label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\"tsne_x\" id=\"cb_43\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_43\">tsne_x</label></div><br style=\"clear: both;\"><div style=\"width: auto; display: inline-block; white-space: nowrap;\"><input type=\"checkbox\" value=\"tsne_y\" id=\"cb_44\" class=\"checkbox\" style=\"float: left;\"><label for=\"cb_44\">tsne_y</label></div><br style=\"clear: both;\"></div><button onclick=\"CheckAll(document.getElementById(`options`));\" style=\"float: left; width:50%;\">Check all</button><button onclick=\"CheckAll(document.getElementById(`options`), false);\" style=\"float: left; width:50%;\" class=\"rightbutton\">Uncheck all</button><button onclick=\"CheckRegex(document.getElementById(`options`));\" style=\"float: left; width:50%;\" class=\"bottombutton\">Check regex</button><button onclick=\"CheckRegex(document.getElementById(`options`), false);\" style=\"float: left; width:50%;\" class=\"bottomrightbutton\">Uncheck regex</button><input class=\"checkregex_input\" style=\"width: 100%;\" value=\"^x\\d+\"><br style=\"clear: both;\"><hr style=\"\"><label style=\"float: left; width: 100px;\">Separator:</label>\n            <select id=\"sep_select\">\n                <option value=\";\">;</option>\n                <option value=\",\">,</option>\n                <option value=\" \"> </option>\n                <option value=\"\t\">\\t</option>\n            </select>\n        <h1 style=\"\">File Name</h1><input id=\"file_name\" type=\"text\" value=\"dataset.csv\" style=\"width: 100%;\"><hr style=\"\"><div style=\"text-align: center;\"><button style=\"border-style: solid;\" onclick=\"save_options.Run();\">Save dataset</button></div><button onmouseover=\"this.style.opacity=1\" onmouseout=\"this.style.opacity=0.5\" style=\"position: absolute; top: 0px; right: 0px; opacity: 0.5; border-style: solid;\">x</button><button onmouseover=\"this.style.opacity=1\" onmouseout=\"this.style.opacity=0.5\" style=\"position: absolute; top: 0px; right: 0px; opacity: 0.5; border-style: solid; --mx: 7.1180419921875; --my: 11;\">x</button></div>\n\n        <script type=\"text/javascript\" src=\"../js/loaddataset.js\"></script>\n        <script type=\"text/javascript\" src=\"../js/modulemanager.js\"></script>\n        <script type=\"text/javascript\" src=\"../js/FPMDataManager.js\"></script>\n        <script type=\"text/javascript\">\n\n            if (typeof pyodide === 'undefined') {\n                var pyodide = null;\n                main();\n            }\n            async function main() {\n                var loaded = false;\n                async function loadp() {\n                    var p = await loadPyodide({ indexURL: \"../pyodide\" , stdout: async (text) => {await pyPrint(text)}});\n                    await p.loadPackage([\"pandas\", 'micropip']);\n                    // await p.runPythonAsync(`\n                    //     import micropip\n                    //     await micropip.install('google')\n                    //     await micropip.install('protobuf')\n                    //     # await micropip.install('opt_protobuf_0.0.1-py3-none-any.whl')\n                    //     from google.protobuf import text_format\n                    //     `\n                    // );\n                    p.runPython(`import pandas as pd\nimport io, base64\nimport js\nfrom csv import Sniffer\nimport inspect\n\ndataframes = []\n\ndef __AddDataframe(value, check_has_header=False):\n    try:\n        splitvalues = value.split(\"\\\\n\")[:2]\n        if len(splitvalues) == 2:\n            splitvalue = splitvalues[0] + splitvalues[1]\n        else:\n            splitvalue = splitvalues[0]\n\n        sniffer = Sniffer()\n        dialect = sniffer.sniff(splitvalue)#, [',', ';', ' ', '\\t', r'\\s'])\n        delim = dialect.delimiter\n        if delim == '.':\n            delim = ';'\n\n        # has_header = sniffer.has_header(value)\n        has_header = True\n    except Exception as e:\n        print(e)\n        delim = ';'\n        has_header = True\n    \n    if has_header or not check_has_header:\n        try:\n            df = pd.read_csv(io.StringIO(value), sep=delim)\n        except Exception as e:\n            return False\n\n        for col in df.columns:\n            if \" \" in col:\n                js.alert(\"One or more columns contain a space (' '), this may lead to unintended behavior.\")\n                break\n\n    else: \n        try:\n            df = pd.read_csv(io.StringIO(value), sep=delim, header=None)\n        except Exception as e:\n            return False\n        columns = ['unnamed_'+str(x) for x in df.columns]\n        df.columns = columns\n    if '__highlight_color' not in df:\n        df['__highlight_color'] = [\"\"]*df.shape[0]\n    \n    if '__filter' not in df:\n        df['__filter'] = [0]*df.shape[0]\n\n    df = df.fillna(\"\")\n    dataframes.append(df)\n\n    return True\n\ndef ParseDataframe(index):\n    df = dataframes[index]\n    #return df.to_csv(sep=',', index=False)\n    return df.to_json(orient='records')\n\ndef ParseToCSV(index, columns=None):\n    if columns:\n        df = dataframes[index][columns]\n    else:\n        df = dataframes[index]\n    return df.to_csv(sep=';', index=False)\n\ndef AddNewDataFrame(df, name:str):\n    js.window.AddDatasetFromPython(df.to_csv(index=False, sep=';'), name)\n\ndef UpdateHighlightColor(index, colors):\n    dataframes[index]['__highlight_color'] = colors;\n\ndef UpdateFilter(index, filter):\n    dataframes[index]['__filter'] = filter;\n\ndef GetDataframeHead(index):\n    ret = \"\"\n    for x in dataframes[index].columns:\n        ret = ret + x + \";\"\n    return ret[:-1]\n\ndef GetUniqueSelections(index):\n    ret = \"\"\n    for x in set(dataframes[index]['__highlight_color']):\n        ret = ret + x + \";\"\n    return ret[:-1]\n\nasync def UpdatePlots(index = None, columns=[]):\n    js.DataUpdateCallback(index, columns)\n    await Output()\n\ndef AddMatplotPlot(fig=None):\n    if fig == None:\n        fig = matplotlib.pyplot.gcf()\n    buf = io.StringIO()\n    fig.savefig(buf, format='svg')\n    img_str = buf.getvalue()\n\n    js._addMatoplotlibIframeImage(img_str)\n\ndef NDS(df, objective_columns:[], minimize:[], limit = -1):\n    _df = df[objective_columns]\n    min = [str(1) if x else str(0) for x in minimize]\n    min = ';'.join(min)\n    csv = _df.to_csv(index=False, sep=';', header=False)\n    csv=csv[:-1]\n    if limit == -1:\n        rank = js.Module.GetRank(csv, min)\n    else:\n        rank = js.Module.GetRankLimited(csv, min, limit)\n    nds = []\n    for x in range(rank.size()):\n        nds.append(rank[x])\n\n    rank.delete()\n\n    df['nds_rank'] = nds\n\nasync def Output():\n    await js.jsSleep(10)   \n                        `);\n                    pyodide = p;\n                        // LoadProtobuf();\n                        //pyodide.runPython(python_asyncio);\n                    loaded = true;\n                    pyodide.loadPackage([\"scikit-learn\", \"matplotlib\"]).then(() => {\n                        pyodide.runPython(python_lhs);\n                        pyodide.runPython('import matplotlib');\n                    });\n                    // pyodide.runPythonAsync(\"from sklearn.manifold import TSNE\");\n                    pyodide.runPython(python_color_blend);\n                }\n                try {\n                    loadp();\n                } catch (error) {\n                    console.log(error);\n                }\n                OpenPopup(\"Wait for Python to load (may take a few moments)...\");\n                function checkLoad() {\n                    if (!loaded) {\n                        window.setTimeout(checkLoad, 100);\n                    }else {\n                        ClosePopup();\n                    }\n                }\n                checkLoad();\n            }\n\n            // todo: move this to module manager!!!!\n            function _addMatoplotlibIframeImage(str){\n                var ifrm = AddModule(-1)\n                \n                // make a dummy 'module' and add SaveImage function to save the svg\n                ifrm.contentWindow.module = {};\n                ifrm.contentWindow.module.SaveImage =  function(module) {\n                    var serializer = new XMLSerializer();\n                    var source = serializer.serializeToString(ifrm.contentWindow.module.svg);\n\n                    var file = new Blob([source], {type: \"octet/stream\"});\n                    if (window.navigator.msSaveOrOpenBlob) // IE10+\n                        window.navigator.msSaveOrOpenBlob(file, filename);\n                    else { // Others\n                        var a = document.createElement(\"a\"),\n                                url = URL.createObjectURL(file);\n                        a.href = url;\n                        a.download = 'image.svg';\n                        document.body.appendChild(a);\n                        a.click();\n                        setTimeout(function() {\n                            document.body.removeChild(a);\n                            window.URL.revokeObjectURL(url);  \n                        }, 0); \n                    }\n                }\n\n                // it is not loaded yet\n                ifrm.addEventListener(\"load\", function() {\n                    var main_div = ifrm.contentDocument.getElementById('main_div')\n                    main_div.innerHTML = str;\n\n                    var svg = main_div.getElementsByTagName('svg')[0];\n                    svg.setAttribute('height', \"100%\");\n                    svg.setAttribute('width', \"100%\");\n\n                    ifrm.contentWindow.module.svg = svg;\n\n                    \n                    var x = ifrm.contentWindow.document.getElementById(\"modify_button\");\n                    x.style.display = 'none';\n                    x = ifrm.contentWindow.document.getElementById(\"reset_button\");\n                    x.style.display = 'none';\n                });\n            }\n            async function jsSleep(ms) {\n                await new Promise(resolve => setTimeout(resolve, ms));\n            }\n        </script>\n        <!-- <br style=\"clear: both;\"> -->\n        <div id=\"right_content\" style=\"flex:1;position:relative; width: 100%; height: 100%; display: flex; flex-direction: column;\">\n            <div id=\"main_content\" class=\"interact-resize-b\" style=\"height: 84.5188%; float: left; resize: vertical; overflow: hidden auto; --mx: 1209.9999694824219; --my: 493;\"><iframe src=\"../html/module.html\" id=\"module_0\" class=\"interact-resize-b-r\" style=\"width: 480px; height: 480px; resize: both; float: left; min-width: 50px; min-height: 50px; --mx: 356.9999694824219; --my: 478;\"></iframe><iframe src=\"../html/module.html\" id=\"module_0\" class=\"interact-resize-b-r\" style=\"width: 480px; height: 480px; resize: both; float: left; min-width: 50px; min-height: 50px; --mx: 212.99993896484375; --my: 478;\"></iframe><iframe src=\"../html/module.html\" id=\"module_0\" class=\"interact-resize-b-r\" style=\"width: 480px; height: 480px; resize: both; float: left; min-width: 50px; min-height: 50px; --mx: 119.9998779296875; --my: 478;\"></iframe><iframe src=\"../html/module.html\" id=\"module_0\" class=\"interact-resize-b-r\" style=\"width: 909px; height: 624px; resize: both; float: left; min-width: 50px; min-height: 50px; --mx: 86.99999237060547; --my: -0.000030517578125;\"></iframe><iframe src=\"../html/module.html\" id=\"module_0\" class=\"interact-resize-b-r\" style=\"width: 1817px; height: 460px; resize: both; float: left; min-width: 50px; min-height: 50px; --mx: 1086.9999694824219; --my: -0.659759521484375;\"></iframe>\n                \n                <div id=\"popupList\">\n                </div>\n            </div>\n            <div id=\"console\" style=\"position: relative; height: 100%; width: 100%; max-width: 100%; flex: 1 1 0%; display: flex; border-top: 1px solid black; min-he